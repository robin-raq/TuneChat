{
  "name": "tunechat",
  "version": "2.0.0",
  "description": "Realtime chat app with rooms and tunes",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/server.js",
    "client": "vite",
    "build": "vite build",
    "start": "node server/server.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": ["chat", "node.js", "socket.io", "tone.js", "realtime"],
  "author": "Raq Robinson",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "moment": "^2.30.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tone": "^14.9.17"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "vite": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
